{
    "source": {
        "include": [
            "api.js"
        ],
        "includePattern": ".js$",
        "excludePattern": "(node_modules|docs)"
    },
    "opts": {
    "destination": "./docs",
    "template": "node_modules/minami",
    "encoding": "utf8",
    "recurse": true
    },
    "templates": {
        "cleverLinks": true,
        "monospaceLinks": true
    }
}